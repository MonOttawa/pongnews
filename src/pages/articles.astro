---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categories = [...new Set(articles.map(a => a.data.category))].sort();
---

<Layout title="All Articles | Pong News" description="Browse all peer-reviewed research articles on table tennis health benefits.">
  <div class="page-header page-header--wide">
    <h1 class="page-header__title">All Articles</h1>
    <p class="page-header__subtitle">Every claim backed by peer-reviewed research.</p>

    <!-- Category Filters -->
    <div class="category-filters">
      {categories.map(cat => (
        <a href={`/category/${encodeURIComponent(cat)}`} class="category-pill category-pill--inactive">{cat}</a>
      ))}
    </div>
  </div>

  <div class="container container--wide">
    <div class="articles-page-grid">
      {sorted.map((article) => (
        <a href={`/article/${article.id}`} class="article-list-card">
          <div class="article-list-card__meta">
            <span class="tag">{article.data.category}</span>
            <span class="article-list-card__date">
              {article.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
          </div>
          <h2 class="article-list-card__title">{article.data.title}</h2>
          <p class="article-list-card__excerpt">{article.data.summary}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
