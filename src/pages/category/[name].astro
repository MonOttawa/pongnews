---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const categories = [...new Set(articles.map(a => a.data.category))];
  return categories.map(category => ({
    params: { name: category },
    props: {
      category,
      articles: articles
        .filter(a => a.data.category === category)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    },
  }));
}

const { category, articles } = Astro.props;
const allArticles = await getCollection('articles');
const allCategories = [...new Set(allArticles.map(a => a.data.category))].sort();

const categoryDescriptions: Record<string, string> = {
  "Longevity": "How table tennis extends lifespan, reduces mortality risk, and transforms aging. Research on life expectancy, mortality reduction, and aging biomarkers.",
  "Cognitive Health": "The neuroscience of ping pong: Alzheimer's defense, dementia prevention, BDNF production, neuroplasticity, and brain structure changes.",
  "Physical Health": "Bone density, balance, fall prevention, cardiovascular fitness, and musculoskeletal benefits of regular table tennis play.",
  "Rehabilitation": "How table tennis aids recovery from Parkinson's, stroke, and other conditions. Motor control, therapy, and clinical outcomes.",
  "Mental Health": "Depression, anxiety, social isolation, quality of life, and psychological well-being benefits of table tennis.",
};
const description = categoryDescriptions[category] || `Articles about table tennis and ${category.toLowerCase()}. Backed by peer-reviewed research.`;
---

<Layout title={`${category} | Pong News`} description={description}>
  <div class="page-header page-header--wide">
    <a href="/articles" class="page-header__back-link">&larr; All Articles</a>
    <h1 class="page-header__title">{category}</h1>
    <p class="page-header__subtitle">{description}</p>

    <!-- Category Filters -->
    <div class="category-filters">
      {allCategories.map(cat => (
        <a href={`/category/${encodeURIComponent(cat)}`}
           class={`category-pill ${cat === category ? 'category-pill--active' : 'category-pill--inactive'}`}>
          {cat}
        </a>
      ))}
    </div>
  </div>

  <div class="container container--wide">
    <div class="article-list">
      {articles.map((article) => (
        <a href={`/article/${article.id}`} class="article-list-card">
          <div class="article-list-card__meta">
            <span class="article-list-card__date">
              {article.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
          </div>
          <h2 class="article-list-card__title">{article.data.title}</h2>
          <p class="article-list-card__excerpt">{article.data.summary}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
