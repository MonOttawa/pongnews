---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = sorted[0];
const rest = sorted.slice(1);
---

<Layout title="Pong News — Table Tennis. Science-Backed Health.">
  
  <!-- Hero -->
  <section style="background: linear-gradient(160deg, #1a1916 0%, #2a2520 40%, #3d2e24 100%); color: #f2ede4; padding: 5rem 1.25rem;">
    <div style="max-width: 42rem; margin: 0 auto; text-align: center;">
      <h1 style="font-family: var(--serif); font-size: 2.8rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin: 0;">
        The Health Benefits of<br/>
        <em style="color: var(--accent-soft);">Table Tennis</em>
      </h1>
      <p style="margin-top: 1.2rem; font-size: 1.15rem; line-height: 1.7; color: rgba(242,237,228,0.75); max-width: 34rem; margin-left: auto; margin-right: auto;">
        Every claim backed by peer-reviewed research. We review the latest scientific studies on how ping pong extends life, protects the brain, and transforms aging.
      </p>
      <div style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem;">
        <span style="background: rgba(255,255,255,0.08); padding: 0.35rem 0.9rem; border-radius: 999px; font-size: 0.8rem;">+9.7 Years Life Expectancy</span>
        <span style="background: rgba(255,255,255,0.08); padding: 0.35rem 0.9rem; border-radius: 999px; font-size: 0.8rem;">47% Lower Mortality</span>
        <span style="background: rgba(255,255,255,0.08); padding: 0.35rem 0.9rem; border-radius: 999px; font-size: 0.8rem;">BDNF Brain Boost</span>
        <span style="background: rgba(255,255,255,0.08); padding: 0.35rem 0.9rem; border-radius: 999px; font-size: 0.8rem;">Prevents Dementia</span>
      </div>
    </div>
  </section>

  <!-- Featured Article -->
  {featured && (
    <section style="max-width: 48rem; margin: -2rem auto 0; padding: 0 1.25rem;">
      <a href={`/article/${featured.id}`} style="background: var(--bg-panel); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2rem 2.5rem; display: block; text-decoration: none; color: inherit; box-shadow: 0 4px 20px rgba(26,25,22,0.08); transition: box-shadow 0.2s;">
        <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem;">
          <span class="tag">{featured.data.category}</span>
          <span style="font-size: 0.78rem; color: var(--text-faint);">5 min read</span>
        </div>
        <h2 style="font-family: var(--serif); font-size: 1.8rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin: 0; color: var(--text-strong);">
          {featured.data.title}
        </h2>
        <p style="margin-top: 0.8rem; color: var(--text-muted); line-height: 1.6; font-size: 1rem;">
          {featured.data.summary}
        </p>
        <div style="margin-top: 0.8rem; font-size: 0.78rem; color: var(--text-faint);">
          {featured.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </div>
      </a>
    </section>
  )}

  <!-- Key Stats -->
  <section style="max-width: 48rem; margin: 3rem auto 0; padding: 0 1.25rem;">
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem;">
      <div class="stat-card" style="background: var(--accent-tint);">
        <div class="stat-number" style="color: var(--accent);">+9.7</div>
        <div class="stat-label" style="color: var(--accent-hover);">Years added to life</div>
        <div class="stat-source">Mayo Clinic Proceedings</div>
      </div>
      <div class="stat-card" style="background: var(--amber-bg);">
        <div class="stat-number" style="color: var(--amber);">47%</div>
        <div class="stat-label" style="color: var(--amber);">Lower mortality</div>
        <div class="stat-source">British J. Sports Med</div>
      </div>
      <div class="stat-card" style="background: var(--blue-bg);">
        <div class="stat-number" style="color: var(--blue);">1.44</div>
        <div class="stat-label" style="color: var(--blue);">Cognitive effect size</div>
        <div class="stat-source">Acta Psychologica 2025</div>
      </div>
      <div class="stat-card" style="background: var(--purple-bg);">
        <div class="stat-number" style="color: var(--purple);">40%</div>
        <div class="stat-label" style="color: var(--purple);">Dementia preventable</div>
        <div class="stat-source">WHO / Lancet</div>
      </div>
    </div>
  </section>

  <!-- Article Grid -->
  <section style="max-width: 48rem; margin: 3rem auto 0; padding: 0 1.25rem;">
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
      {rest.map((article) => (
        <a href={`/article/${article.id}`} class="card" style="text-decoration: none;">
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
            <span class="tag">{article.data.category}</span>
          </div>
          <h3 style="font-family: var(--serif); font-weight: 600; font-size: 1.1rem; line-height: 1.3; margin: 0; letter-spacing: -0.01em; color: var(--text-strong);">
            {article.data.title}
          </h3>
          <p style="margin-top: 0.5rem; font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
            {article.data.summary}
          </p>
          <div style="margin-top: 0.6rem; font-size: 0.75rem; color: var(--text-faint);">
            {article.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Share CTA -->
  <section style="max-width: 48rem; margin: 4rem auto 0; padding: 0 1.25rem 4rem;">
    <div style="background: var(--bg-subtle); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem; text-align: center;">
      <h3 style="font-family: var(--serif); font-weight: 600; font-size: 1.25rem; margin: 0; color: var(--text-strong);">Know someone who plays table tennis?</h3>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.5rem 0 0;">Share the science. One link could change how someone approaches their health.</p>
      <div style="margin-top: 1rem; display: flex; justify-content: center; gap: 0.5rem;">
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent('Table tennis can add 10 years to your life. The science is incredible:')}`} target="_blank" rel="noopener noreferrer" class="share-btn">Share on X</a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://pongnews.com')}`} target="_blank" rel="noopener noreferrer" class="share-btn">Facebook</a>
      </div>
    </div>
  </section>

</Layout>
