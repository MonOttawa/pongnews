---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const wordCount = article.body?.length || 0;
const readTime = Math.max(1, Math.round(wordCount / 1200));
const shareUrl = `https://pongnews.com/article/${article.id}`;
const shareText = `${article.data.title} — Pong News`;

// Get related articles
const allArticles = await getCollection('articles');
const related = allArticles
  .filter(a => a.id !== article.id)
  .map(a => {
    const sharedTags = a.data.tags.filter(t => article.data.tags.includes(t)).length;
    const sameCat = a.data.category === article.data.category ? 2 : 0;
    return { article: a, score: sharedTags + sameCat };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

<Layout
  title={`${article.data.title} | Pong News`}
  description={article.data.summary}
  article={true}
  pubDate={article.data.date}
  tags={article.data.tags}
>
  <article class="article-page">

    <!-- Header -->
    <header class="article-header">
      <div class="article-header__meta">
        <a href={`/category/${encodeURIComponent(article.data.category)}`} class="tag">{article.data.category}</a>
        <span class="article-header__detail">{readTime} min read</span>
        <span class="article-header__separator">·</span>
        <span class="article-header__detail">
          {article.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
      </div>
      <h1 class="article-header__title">{article.data.title}</h1>
      <p class="article-header__summary">{article.data.summary}</p>
    </header>

    <!-- Hero Image -->
    <div class="article-hero-image">
      <img src={article.data.image} alt="" />
    </div>

    <!-- Share Bar -->
    <div class="article-share-bar">
      <span class="article-share-bar__label">Share</span>
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">X</a>
      <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">Facebook</a>
      <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareText)}`} target="_blank" rel="noopener noreferrer" class="share-btn">Reddit</a>
      <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(shareText + ' ' + shareUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">WhatsApp</a>
    </div>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Sources -->
    {article.data.sources.length > 0 && (
      <div class="article-sources">
        <h4 class="article-sources__heading">Peer-Reviewed Sources</h4>
        <ul class="article-sources__list">
          {article.data.sources.map((source: any) => {
            const text = typeof source === 'string' ? source : source.text;
            const url = typeof source === 'string' ? null : source.url;
            return url ? (
              <li class="article-sources__item"><a href={url} target="_blank" rel="noopener noreferrer" class="article-sources__link">{text} &#8599;</a></li>
            ) : (
              <li class="article-sources__item">{text}</li>
            );
          })}
        </ul>
      </div>
    )}

    <!-- Tags -->
    <div class="article-tags">
      {article.data.tags.map((tag: string) => (
        <span class="article-tags__item">{tag}</span>
      ))}
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div class="related-articles">
        <h4 class="related-articles__heading">Related Articles</h4>
        <div class="related-articles__grid">
          {related.map(({ article: r }) => (
            <a href={`/article/${r.id}`} class="related-card">
              <img src={r.data.image} alt="" class="related-card__image" loading="lazy" />
              <div class="related-card__body">
                <div class="related-card__category">{r.data.category}</div>
                <div class="related-card__title">{r.data.title}</div>
                <div class="related-card__date">
                  {r.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>

  <!-- Back to top -->
  <a href="#" class="back-to-top" aria-label="Back to top">&#8593;</a>
</Layout>
