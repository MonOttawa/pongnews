---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const wordCount = article.body?.length || 0;
const readTime = Math.max(1, Math.round(wordCount / 1200));
const shareUrl = `https://pongnews.com/article/${article.id}`;
const shareText = `${article.data.title} — Pong News`;

// Get related articles
const allArticles = await getCollection('articles');
const related = allArticles
  .filter(a => a.id !== article.id)
  .map(a => {
    const sharedTags = a.data.tags.filter(t => article.data.tags.includes(t)).length;
    const sameCat = a.data.category === article.data.category ? 2 : 0;
    return { article: a, score: sharedTags + sameCat };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

<Layout 
  title={`${article.data.title} | Pong News`}
  description={article.data.summary}
  article={true}
  pubDate={article.data.date}
  tags={article.data.tags}
>
  <article style="max-width: 42rem; margin: 0 auto; padding: 2.5rem 1.25rem;">
    
    <!-- Header -->
    <header style="margin-bottom: 2rem;">
      <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.8rem;">
        <a href={`/category/${encodeURIComponent(article.data.category)}`} class="tag" style="text-decoration: none;">{article.data.category}</a>
        <span style="font-size: 0.78rem; color: var(--text-faint);">{readTime} min read</span>
        <span style="color: var(--text-faint);">·</span>
        <span style="font-size: 0.78rem; color: var(--text-faint);">
          {article.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
      </div>
      <h1 style="font-family: var(--serif); font-size: 2.4rem; font-weight: 700; line-height: 1.15; letter-spacing: -0.025em; color: var(--text-strong); margin: 0;">
        {article.data.title}
      </h1>
      <p style="margin-top: 1rem; font-size: 1.1rem; color: var(--text-muted); line-height: 1.6; font-family: var(--serif);">
        {article.data.summary}
      </p>
    </header>

    <!-- Share Bar -->
    <div style="display: flex; align-items: center; gap: 0.4rem; padding: 0.6rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: 2rem;">
      <span style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-faint); font-weight: 600; margin-right: 0.3rem;">Share</span>
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">X</a>
      <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">Facebook</a>
      <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareText)}`} target="_blank" rel="noopener noreferrer" class="share-btn">Reddit</a>
      <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(shareText + ' ' + shareUrl)}`} target="_blank" rel="noopener noreferrer" class="share-btn">WhatsApp</a>
    </div>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Sources -->
    {article.data.sources.length > 0 && (
      <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
        <h4 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-faint); font-weight: 600; margin: 0 0 0.75rem;">Peer-Reviewed Sources</h4>
        <ul style="list-style: none; padding: 0; margin: 0;">
          {article.data.sources.map((source: string) => (
            <li style="font-size: 0.82rem; color: var(--text-soft); padding: 0.2rem 0; line-height: 1.5;">{source}</li>
          ))}
        </ul>
      </div>
    )}

    <!-- Tags -->
    <div style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.4rem;">
      {article.data.tags.map((tag: string) => (
        <span style="background: var(--bg-subtle); color: var(--text-muted); padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem;">{tag}</span>
      ))}
    </div>

    <!-- Newsletter Inline -->
    <div style="margin-top: 3rem; background: var(--accent-tint); border: 1px solid var(--accent-soft); border-radius: var(--radius-lg); padding: 1.5rem;">
      <h3 style="font-family: var(--serif); font-weight: 700; font-size: 1.1rem; color: var(--text-strong); margin: 0;">Get the Weekly Pong</h3>
      <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0.3rem 0 0;">Science-backed insights, weekly. Free.</p>
      <form style="margin-top: 0.8rem; display: flex; gap: 0.4rem;" action="https://formspree.io/f/placeholder" method="POST">
        <input type="email" name="email" placeholder="your@email.com" required
          style="flex: 1; padding: 0.45rem 0.7rem; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 0.85rem; background: var(--bg-panel); outline: none;"
        />
        <button type="submit" style="background: var(--accent); color: white; padding: 0.45rem 1rem; border: none; border-radius: var(--radius-sm); font-weight: 500; font-size: 0.8rem; cursor: pointer;">Subscribe</button>
      </form>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div style="margin-top: 3rem;">
        <h4 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-faint); font-weight: 600; margin: 0 0 1rem;">Related Articles</h4>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
          {related.map(({ article: r }) => (
            <a href={`/article/${r.id}`} style="background: var(--bg-panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; text-decoration: none; color: inherit; display: block; transition: border-color 0.15s;">
              <div style="font-size: 0.7rem; color: var(--accent); font-weight: 500; margin-bottom: 0.3rem;">{r.data.category}</div>
              <div style="font-family: var(--serif); font-weight: 600; font-size: 0.85rem; line-height: 1.3; color: var(--text-strong);">{r.data.title}</div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>
