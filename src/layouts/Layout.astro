---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  pubDate?: Date;
  tags?: string[];
}

const { title, description = 'The science of table tennis and health. Peer-reviewed research on how ping pong extends life, protects the brain, and transforms aging.', ogImage, article = false, pubDate, tags = [] } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#faf9f7" />

    <!-- Preload Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300;400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />

    <!-- SVG Favicon (table tennis paddle) -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Pong News" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Pong News",
      "url": "https://pongnews.com",
      "description": description
    })} />
  </head>
  <body>
    <!-- SVG Noise Grain Overlay -->
    <div class="grain"></div>

    <!-- Navigation -->
    <nav class="site-nav" aria-label="Main navigation">
      <div class="site-nav__inner">
        <a href="/" class="site-nav__logo">
          <img src="/images/logo.png" alt="Pong News" class="site-nav__logo-img" />
        </a>

        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation" />
        <label for="nav-toggle" class="nav-toggle-label" aria-label="Open menu">
          <span></span>
        </label>

        <ul class="site-nav__links">
          <li><a href="/articles">Articles</a></li>
          <li><a href="/category/Longevity">Longevity</a></li>
          <li><a href="/category/Cognitive%20Health">Brain</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
    </nav>

    <main class="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="site-footer__inner">

        <div class="footer-columns">
          <div>
            <div class="footer-columns__brand-name">Pong News</div>
            <div>Where table tennis meets science.<br/>All claims backed by peer-reviewed research.</div>
          </div>
          <div class="footer-columns__links">
            <a href="/about">About</a>
            <a href="/articles">Articles</a>
            <a href="/sitemap-index.xml">Sitemap</a>
          </div>
        </div>

        <div class="footer-bottom">
          {currentYear} Pong News. All rights reserved.
        </div>
      </div>
    </footer>
  </body>
</html>
